{
    "$schema": "https://typedoc-plugin-markdown.org/schema.json",
    "entryPoints": ["./packages/core/src/index.ts"],
    "tsconfig": "./packages/core/tsconfig.json",
    "skipErrorChecking": true,
    "out": "./docs/api",
    "docsRoot": "./docs",
    "plugin": ["typedoc-plugin-markdown", "typedoc-vitepress-theme"],
    "excludeInternal": true,
    "excludePrivate": true,
    "excludeProtected": true,
    "categorizeByGroup": true,
    "hidePageHeader": true,
    "hideBreadcrumbs": true,
    "useCodeBlocks": true,
    "expandObjects": true,
    "parametersFormat": "table",
    "enumMembersFormat": "table",
    "typeDeclarationFormat": "table",
    "intentionallyNotExported": [
        "ParamsMap",
        "IntrospectionConfig",
        "OAuthConfig",
        "ToolRegistryLike",
        "McpServerLike",
        "EvasionIndicator",
        "PromptContentBlock",
        "ProbeContractContext",
        "SemanticThresholds",
        "CorsConfig",
        "ServerRegistry",
        "ServerTransport",
        "FluentProxy",
        "ActionSuggestion",
        "InternalAction",
        "LoopbackContext",
        "InferPromptArgs",
        "SecurityAuditEvent",
        "FieldType",
        "AsyncCollectionUiBlocksFn",
        "AsyncRulesFn",
        "AsyncSuggestActionsFn",
        "AsyncItemUiBlocksFn",
        "CollectionRulesFn",
        "CollectionSuggestActionsFn",
        "CollectionUiBlocksFn",
        "SuggestActionsFn",
        "ItemUiBlocksFn",
        "PromptPaginationOptions",
        "PromptInterceptorFn",
        "ToolBuilderLike",
        "InferParams",
        "InferSingleParam",
        "ActionHandler",
        "PromptConfigBase",
        "ZodSchemaLike",
        "ServerCardBuilderLike",
        "PromptEntryLike",
        "ResourceEntryLike",
        "AuditSink"
    ],
    "externalSymbolLinkMappings": {
        "@mcpfusion/core": {
            "ErrorBuilder": "#",
            "IntrospectionConfig": "#",
            "ServerAttachment": "#",
            "AuditTrail": "#",
            "StateSyncHint": "#"
        }
    }
}
