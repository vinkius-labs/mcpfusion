{
  "name": "@mcpfusion/cloudflare",
  "version": "4.0.1",
  "description": "Cloudflare Workers adapter for MCP Fusion. Deploys your MCP server to the edge with zero config — stateless JSON-RPC, cold-start caching, and native env injection.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "mcpfusion",
    "cloudflare",
    "workers",
    "edge",
    "serverless",
    "wintercg",
    "ai",
    "llm"
  ],
  "author": "Renato Marinho",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vinkius-labs/mcpfusion.git",
    "directory": "packages/cloudflare"
  },
  "bugs": {
    "url": "https://github.com/vinkius-labs/mcpfusion/issues"
  },
  "homepage": "https://mcpfusion.vinkius.com/",
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@mcpfusion/core": "^4.0.1"
  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0"
  },
  "license": "Apache-2.0",
  "devDependencies": {
    "vitest": "^3.0.0"
  }
