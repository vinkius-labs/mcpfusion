{
  "name": "@mcpfusion/aws",
  "version": "4.0.0",
  "description": "AWS Lambda & Step Functions connector for MCP Fusion. Auto-discovers tagged resources and produces GroupedToolBuilders — so AI agents can invoke your cloud functions natively.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "aws",
    "lambda",
    "step-functions",
    "mcpfusion",
    "serverless",
    "ai",
    "llm",
    "connector"
  ],
  "author": "Renato Marinho",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vinkius-labs/mcpfusion.git",
    "directory": "packages/aws"
  },
  "bugs": {
    "url": "https://github.com/vinkius-labs/mcpfusion/issues"
  },
  "homepage": "https://mcpfusion.vinkius.com/",
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@mcpfusion/core": "^4.0.0"
  },
  "peerDependencies": {
    "@aws-sdk/client-lambda": "^3.0.0",
    "@aws-sdk/client-sfn": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "@aws-sdk/client-lambda": {
      "optional": true
    },
    "@aws-sdk/client-sfn": {
      "optional": true
    }
  },
  "devDependencies": {
    "@aws-sdk/client-lambda": "^3.0.0",
    "@aws-sdk/client-sfn": "^3.0.0",
    "@types/node": "^25.3.0"
  },
  "license": "Apache-2.0"
}
